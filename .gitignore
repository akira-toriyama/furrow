# Go build artifacts
/furrow
/bin/
/dist/
*.exe
*.test
*.out
coverage.*

# Nix build artifacts (`nix build` output symlinks)
/result
/result-*

# Go workspace / vendor (kept out until needed)
/vendor/
go.work
go.work.sum

# macOS / editors
.DS_Store
*.swp
.idea/
.vscode/

# Local scratch (reference clones live OUTSIDE this repo)
/.reference/
/tmp/

# No local board in this code repo — its tasks live on the central board
# (akira-toriyama/projects), per CLAUDE.md. Gitignored so a stray `furrow init`
# run from the repo root can never be committed into the code repo again.
/.furrow/
