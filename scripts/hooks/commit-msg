#!/bin/sh
# commit-msg hook: validate gitmoji + Conventional Commits form.
# Enable:     git config core.hooksPath scripts/hooks
# Convention: docs/commit-convention.md
#
# Form: <:gitmoji:> <type>(<scope>)<!>: <subject>
#   e.g. :sparkles: feat(core): add deterministic index marshaller
#
# Low-dependency (POSIX sh + grep). The gitmoji must be the :code: text form.

msg_file="$1"
subject="$(grep -vE '^[[:space:]]*#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)"

case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

types='feat|fix|perf|refactor|docs|test|build|ci|chore|style|revert'
pattern="^:[a-z0-9][a-z0-9_+-]*: ($types)(\([^()]+\))?!?: .+"

if printf '%s' "$subject" | grep -qE "$pattern"; then
  exit 0
fi

cat >&2 <<EOF
✖ Commit message violates the convention.

  got: $subject

  form: <:gitmoji:> <type>(<scope>)<!>: <subject>
        ^^^^^^^^^^^ :code: text form required (emoji glyph rejected)

  type: $types
  scope: core|store|config|cli|tui|index|body|migrate|packaging|ci|docs
  e.g.: :sparkles: feat(core): add deterministic index marshaller
        :bug: fix(store): atomic-rename the index, never partial-write
        :boom: feat(cli)!: rename --status to --lane

  details: docs/commit-convention.md
EOF
exit 1
